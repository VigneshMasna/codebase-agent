# ── Neo4j (AuraDB or self-hosted) ─────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# ── Google Cloud / Gemini ──────────────────────────────────────
# Path to your GCP service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./gcp-credentials.json
GCP_PROJECT_ID=your_gcp_project_id
GCP_LOCATION=global
GEMINI_MODEL=gemini-2.5-flash

# ── HuggingFace Models (optional overrides) ───────────────────
# Default model IDs are already set in vuln_scanner/config/settings.py
# Only set these if you want to use a different HF repo
# GRAPHCODEBERT_C_MODEL_ID=2451-22-749-016/graphcodebert-c-bug-detector
# GRAPHCODEBERT_JAVA_MODEL_ID=2451-22-749-016/graphcodebert-java-bug-detector

# ── Application ───────────────────────────────────────────────
PORT=8000

# ── Frontend (Vite) ───────────────────────────────────────────
# Leave empty for local dev (Vite proxy handles routing)
# Set to your deployed backend URL in production
VITE_API_BASE=
